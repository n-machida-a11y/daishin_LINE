// API呼び出し
function callGeminiApi(prompt) {
  const payload = {
    "contents": [{"parts": [{"text": prompt}]}],
    "generationConfig": {"temperature": 0.2}
  };
  const options = {
    'method': 'post',
    'contentType': 'application/json',
    'payload': JSON.stringify(payload),
    'muteHttpExceptions': true
  };
  try {
    const res = UrlFetchApp.fetch(API_ENDPOINT, options);
    if (res.getResponseCode() === 200) {
      const json = JSON.parse(res.getContentText());
      return json.candidates?.[0]?.content?.parts?.[0]?.text || "No Content";
    }
    return `APIエラー: ${res.getResponseCode()}`;
  } catch (e) { return `通信エラー: ${e.message}`; }
}

// レスポンス解析
function parseGeminiResponseToTables(text) {
  const parentData = [], childData = [];
  let current = null;
  const lines = text.split('\n');
  
  for (const line of lines) {
    const trimmedLine = line.trim();

    if (trimmedLine.includes("親テーブル：案件詳細")) {
      current = parentData;
      continue;
    } else if (trimmedLine.includes("子テーブル：協力会社詳細")) {
      current = childData;
      continue;
    }

    // テーブル行の処理
    if (current && trimmedLine.startsWith('|')) {
      // 1. セパレータ行 (---) はスキップ
      if (trimmedLine.includes('---')) continue;

      // 2. ★修正点: ヘッダー行をスキップ
      // "日付" かつ "現場名" が含まれていれば親テーブルのヘッダーとみなす
      // "協力会社出勤" が含まれていれば子テーブルのヘッダーとみなす
      if (trimmedLine.includes('現場名') || trimmedLine.includes('協力会社出勤')) continue;

      // 3. データ抽出
      // Markdownテーブルは | で区切られており、行頭と行末も | なので、
      // split すると最初と最後が空文字になるため slice(1, -1) で中身を取り出す
      const cells = trimmedLine.split('|').map(c => c.trim());
      if (cells.length > 2) {
        current.push(cells.slice(1, -1));
      }
    }
  }
  return { parentData, childData };
}

