// IDの生成（AppSheet互換：8桁のランダム英数字）
// これにより重複を回避し、AppSheet側との整合性を保ちます
function generateAppSheetId() {
  const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
  let id = '';
  for (let i = 0; i < 8; i++) {
    id += chars.charAt(Math.floor(Math.random() * chars.length));
  }
  return id;
}

// マスタマップ作成
function _createMasterMap(sheetName, keyCol, valCol) {
  const ss = SpreadsheetApp.openById(TARGET_SPREADSHEET_ID);
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return {};
  const data = sheet.getDataRange().getValues();
  const map = {};
  for (let i = 1; i < data.length; i++) {
    let key = data[i][keyCol];
    if (key) {
      if (sheetName === "会社マスタ") {
        key = key.replace(/^(㈱|㈲|\(株\)|\(有\)|（株）|（有）|株式会社|有限会社|合同会社)/, '')
                 .replace(/(㈱|㈲|\(株\)|\(有\)|（株）|（有）|株式会社|有限会社|合同会社)$/, '')
                 .trim();
      }
      map[key] = data[i][valCol];
    }
  }
  return map;
}

// 現場コード検索
function findGenbaCode(companyCode, siteName, masterData) {
  for (const row of masterData) {
    if (row[1] == companyCode && row[2] == siteName) return row[0];
  }
  return null;
}

// データ追記
function appendDataToSheet(sheetName, dataArray) {
  const ss = SpreadsheetApp.openById(TARGET_SPREADSHEET_ID);
  const sheet = ss.getSheetByName(sheetName);
  if (sheet && dataArray.length > 0) {
    sheet.getRange(sheet.getLastRow() + 1, 1, dataArray.length, dataArray[0].length).setValues(dataArray);
  }
}

// ログ保存
function debugLog(text) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    let sheet = ss.getSheetByName('Debug');
    if (!sheet) {
      sheet = ss.insertSheet('Debug');
      sheet.appendRow(['日時', 'ログ内容']);
    }
    sheet.appendRow([new Date(), text]);
  } catch (e) { console.error(e); }
}
